    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference('RevitServices')\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\n# Acessar o documento atual\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# Coletar todas as famílias no modelo\r\ncollector = FilteredElementCollector(doc).OfClass(Family)\r\n\r\n# Filtrar apenas as famílias criadas \"No Local\" (In-Place)\r\nin_place_families = [f for f in collector if f.IsInPlace]\r\nin_place_instances = []\r\n\r\n# Encontrar as instâncias (os elementos 3D) dessas famílias\r\nfor f in in_place_families:\r\n    symbols = f.GetFamilySymbolIds()\r\n    for sym_id in symbols:\r\n        inst_collector = FilteredElementCollector(doc).WherePasses(FamilyInstanceFilter(doc, sym_id))\r\n        in_place_instances.extend([i for i in inst_collector])\r\n\r\n# Saída da lista de elementos para o Dynamo\r\nOUT = in_place_instances",
      "VariableInputPorts": true,
      "Id": "7df01a2208e34cc99fdfa9a6b6671024",
      "Inputs": [
        {
          "Id": "e1e6e7f52fc04afe81f5fc6d62bb1e56",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "be4a3a48b422441496384db6f4b40436",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded IronPython script."
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "NodeType": "CodeBlockNode",
      "Code": "\"FAMILIAS IN-PLACE\";",
      "Id": "d1b49af074da4aef8b82ec0170930b21",
      "Inputs": [],
      "Outputs": [
