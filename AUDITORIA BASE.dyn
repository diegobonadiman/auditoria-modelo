    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nwarnings = doc.GetWarnings()\r\n\r\ndescriptions = [w.GetDescriptionText() for w in warnings]\r\nfailing_elements = [[doc.GetElement(id) for id in w.GetFailingElements()] for w in warnings]\r\n\r\nOUT = descriptions, failing_elements",
      "VariableInputPorts": true,
      "Id": "1c05f7dfb5a043bbbb860552359d8e5e",
      "Inputs": [
        {
          "Id": "0f8a1eeac9d6493d9519a0810b9e9b12",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "c52c34852d2d41bd80811e81abcdf4f3",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded IronPython script."
    },
